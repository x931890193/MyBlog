# Copy this file to .env on the server and fill real values there.
# Never commit the real .env file.

SECRET_KEY=change-me
DEBUG=false
ALLOWED_HOSTS=www.mongona.com,mongona.com,127.0.0.1,localhost
SITE_BASE_URL=https://www.mongona.com
BAIDU_PUSH_TOKEN=

MYSQL_DATABASE=blog
MYSQL_USER=blog
MYSQL_PASSWORD=change-me
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWD=

MONGO_URI=mongodb://127.0.0.1:27017
MONGODB_NAME=blog

HAYSTACK_URL=http://127.0.0.1:9200/
HAYSTACK_INDEX_NAME=blog

STATIC_ROOT=./staticfiles
MEDIA_ROOT=./media
LOG_FILE_PATH=./log/myblog.log
QINIU_STATIC_PREFIX=static
PAGE_CACHE_SECONDS=900
PAGE_CACHE_DEBUG_HEADER=false
SITE_INFO_CACHE_SECONDS=60
BANNER_CACHE_SECONDS=300
REQUEST_INFO_WRITE_INTERVAL_SECONDS=60
IP_REGION_LOOKUP_TIMEOUT_SECONDS=0.4
IP_REGION_LOOKUP_MISS_SECONDS=3600
PERFORMANCE_MONITOR_ENABLED=true
PERFORMANCE_MONITOR_SLOW_MS=400
PERFORMANCE_MONITOR_SAMPLE_PERCENT=10
PERFORMANCE_MONITOR_WRITE_INTERVAL_SECONDS=10
TECH_NEWS_CRON_ENABLED=false

QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET_NAME=
QINIU_BUCKET_DOMAIN=
QINIU_SECURE_URL=true

GITALK_CLIENT_ID=
GITALK_CLIENT_SECRET=

VALINE_APP_ID=
VALINE_APP_KEY=
GOOGLE_AD_CLIENT=

WEATHER_APP_ID=
WEATHER_APP_SECRET=

MUSIC_API_BASE_URL=http://music.bytealien.com
MUSIC_LOGIN_EMAIL=
MUSIC_LOGIN_PASSWORD=
