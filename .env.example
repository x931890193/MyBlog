# Copy this file to .env on the server and fill real values there.
# Never commit the real .env file.

SECRET_KEY=change-me
DEBUG=false
ALLOWED_HOSTS=www.mongona.com,mongona.com,127.0.0.1,localhost
SITE_BASE_URL=https://www.mongona.com
CANONICAL_REDIRECT_ENABLED=true
CANONICAL_HOST=www.mongona.com
CANONICAL_REDIRECT_HOSTS=mongona.com
BAIDU_PUSH_TOKEN=

# Sponsor lead notification. Keep real mailbox passwords or webhook tokens only in .env.
ADMIN_EMAILS=
SPONSOR_LEAD_NOTIFY_EMAILS=
SPONSOR_LEAD_EMAIL_ENABLED=true
SPONSOR_LEAD_FROM_EMAIL=
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=465
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_SSL=true
EMAIL_USE_TLS=false
EMAIL_TIMEOUT_SECONDS=8
DEFAULT_FROM_EMAIL=
SPONSOR_LEAD_WEBHOOK_ENABLED=true
SPONSOR_LEAD_WEBHOOK_URL=
SPONSOR_LEAD_WEBHOOK_KIND=generic
SPONSOR_LEAD_WEBHOOK_TOKEN=
SPONSOR_LEAD_NOTIFY_TIMEOUT_SECONDS=4

MYSQL_DATABASE=blog
MYSQL_USER=blog
MYSQL_PASSWORD=change-me
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWD=

MONGO_URI=mongodb://127.0.0.1:27017
MONGODB_NAME=blog

HAYSTACK_URL=http://127.0.0.1:9200/
HAYSTACK_INDEX_NAME=blog

STATIC_ROOT=./staticfiles
MEDIA_ROOT=./media
LOG_FILE_PATH=./log/myblog.log
QINIU_STATIC_PREFIX=static
PAGE_CACHE_SECONDS=900
PAGE_CACHE_DEBUG_HEADER=false
SITE_INFO_CACHE_SECONDS=60
BANNER_CACHE_SECONDS=300
REQUEST_INFO_WRITE_INTERVAL_SECONDS=60
IP_REGION_LOOKUP_TIMEOUT_SECONDS=0.4
IP_REGION_LOOKUP_MISS_SECONDS=3600
PERFORMANCE_MONITOR_ENABLED=true
PERFORMANCE_MONITOR_SLOW_MS=400
PERFORMANCE_MONITOR_SAMPLE_PERCENT=10
PERFORMANCE_MONITOR_WRITE_INTERVAL_SECONDS=10
TECH_NEWS_CRON_ENABLED=false

# Site assistant. Default stays rules-only; production can enable local_llm
# when the internal GPU Gateway is reachable.
SITE_ASSISTANT_MODE=rules
LOCAL_LLM_BASE_URL=http://127.0.0.1:18080
LOCAL_LLM_BASE_URLS=
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=
LOCAL_LLM_TIMEOUT_SECONDS=4
LOCAL_LLM_MAX_NEW_TOKENS=220
LOCAL_LLM_TEMPERATURE=0.4

QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET_NAME=
QINIU_BUCKET_DOMAIN=
QINIU_SECURE_URL=true

GITALK_CLIENT_ID=
GITALK_CLIENT_SECRET=

VALINE_APP_ID=
VALINE_APP_KEY=
GOOGLE_AD_CLIENT=

WEATHER_APP_ID=
WEATHER_APP_SECRET=

MUSIC_API_BASE_URL=http://music.bytealien.com
MUSIC_LOGIN_EMAIL=
MUSIC_LOGIN_PASSWORD=
